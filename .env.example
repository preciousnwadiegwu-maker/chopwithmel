# Paystack keys — get these from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here

# Your WhatsApp number in international format (no + sign, no spaces)
# e.g. 2348012345678 for a Nigerian number
WHATSAPP_NUMBER=2348012345678

# Admin dashboard token — change this to something secret!
ADMIN_TOKEN=your_secret_admin_token_here

# Server port (Render sets this automatically)
PORT=3000
